# Trade Odds client — config
# Copy to `.env` and edit if you want to override defaults.

# Upstream data server(s). One URL, or a comma-separated fallback chain.
# The client picks the first one that responds and proxies everything to it.
# Defaults (baked into server.mjs, in order):
#   1. Cloudflare Tunnel  — works on ANY machine, anywhere, no Tailscale needed
#   2. Tailscale Funnel   — fallback if Cloudflare goes down (needs Funnel enabled)
#   3. Tailscale tailnet  — direct, only when you're on the tailnet
#
# Example override pointing at just one URL:
# REMOTE_DATA_URL=https://your-cloudflare-tunnel.example.com
#
# Or a custom chain:
# REMOTE_DATA_URL=http://192.168.1.68:7071,https://your-tunnel.com

# Local port the client serves the dashboard on. Change if 7071 conflicts.
PORT=7071
