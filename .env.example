# Trade Odds client — config
# Copy this file to `.env` and edit if you need to override defaults.

# Upstream URL of the canonical Trade Odds instance to proxy data from.
# Default is the public Tailscale Funnel URL of the home Mac mini.
# Override if the upstream moves (or you want to point at a different host).
REMOTE_DATA_URL=https://davids-mac-mini.tailfd4a41.ts.net:8443

# Local port to listen on. Change if 7071 conflicts with something.
PORT=7071
