# Trade Odds — config
# Copy to `.env` and edit. Pick ONE mode below.

# ─────────────────────────────────────────────────────────────
# MODE 1 — Thin client (default). Proxies to a remote canonical
# instance (Mac mini via Cloudflare Tunnel). No keys needed.
# ─────────────────────────────────────────────────────────────
# REMOTE_DATA_URL=https://ottawa-specified-katrina-modes.trycloudflare.com
# (Multiple URLs ok, comma-separated — first that responds wins.)

# Local port for the dashboard.
PORT=7071

# ─────────────────────────────────────────────────────────────
# MODE 2 — Standalone. This machine runs the scanners AND serves
# the dashboard. Needed for resilience when the Mac is offline,
# OR if you want Windows to be self-sufficient. Requires keys below.
# ─────────────────────────────────────────────────────────────
# Set this to disable upstream proxying entirely:
# STANDALONE=1

# ── ClickHouse Cloud warehouse access (read-only is fine) ──
# CLICKHOUSE_URL=https://your-cluster.clickhouse.cloud:8443
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=...
# CLICKHOUSE_DATABASE=default

# ── Polygon (rebranded "Massive" in our codebase) ──
# MASSIVE_API_KEY=...

# ── Unusual Whales ──
# UW_API_KEY=...

# ─────────────────────────────────────────────────────────────
# Cache (Phase 1) — survives reboots, falls back when upstream dies
# ─────────────────────────────────────────────────────────────
# CACHE_DISABLE=1                                 # opt out
# CACHE_DIR=/path/to/cache                        # default ~/.trade-odds-cache
